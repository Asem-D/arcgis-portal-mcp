# ArcGIS Portal MCP - Environment Configuration
# Copy this file to .env and fill in your credentials.
# The server reads these on startup and connects automatically.

# Your ArcGIS Portal or Online URL
# Enterprise Portal example: https://gis.example.com/portal
# ArcGIS Online: https://www.arcgis.com
portal_url=

# Option 1: Username/password (recommended for most users)
# Uses generateToken for user-level auth with full permissions.
# Works with both Enterprise Portal and ArcGIS Online.
username=
password=

# Option 2: OAuth2 app credentials (client_credentials grant)
# App-level token with limited permissions (no user identity).
# Create an OAuth2 app in your portal: Home > Settings > Extensions > OAuth2
# oauth_client_id=
# oauth_client_secret=
